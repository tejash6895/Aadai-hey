{%- assign img = product.featured_image -%}
<article class="card-product">
  <a href="{{ product.url }}">
    <div class="media {{ aspect | default: 'square' }}">
      {% if img %}
        <img loading="lazy" src="{{ img | image_url: width: 900 }}" alt="{{ product.title | escape }}">
      {% endif %}
      {% if product.tags contains 'new' %}
        <span class="badge">New</span>
      {% endif %}
    </div>
    <h3 class="title">{{ product.title }}</h3>
    {% render 'price', product: product %}
    {%- assign size_opt = product.options_with_values | where: 'name', 'Size' | first -%}
    {% if size_opt and size_opt.values.size > 0 %}
      <div class="sizes">
        {% for s in size_opt.values %}
          <span class="size-pill">{{ s }}</span>
        {% endfor %}
      </div>
    {% endif %}
  </a>
</article>
