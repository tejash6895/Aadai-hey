<section class="hero-slideshow">
  <div class="slides" data-autoplay="true" data-interval="6000">
    {% for block in section.blocks %}
      <div class="slide{% if section.settings.kenburns %} kenburns{% endif %}">
        {% if block.settings.image %}
          <img src="{{ block.settings.image | image_url: width: 2400 }}" alt="{{ block.settings.heading | escape }}">
        {% endif %}
        {% if block.settings.heading or block.settings.subheading or block.settings.link_label %}
          <div class="slide-overlay" style="--overlay: {{ block.settings.overlay | divided_by: 100.0 }};">
            {% if block.settings.kicker != blank %}<p class="kicker">{{ block.settings.kicker }}</p>{% endif %}
            {% if block.settings.heading != blank %}<h2>{{ block.settings.heading }}</h2>{% endif %}
            {% if block.settings.subheading != blank %}<p class="sub">{{ block.settings.subheading }}</p>{% endif %}
            {% if block.settings.link_label != blank %}
              <a href="{{ block.settings.link_url }}" class="button">{{ block.settings.link_label }}</a>
            {% endif %}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Hero slideshow",
  "settings":[
    { "type":"checkbox","id":"kenburns","label":"Gentle zoom (Ken Burns)","default": true }
  ],
  "blocks":[
    { "type":"slide","name":"Slide","settings":[
      { "type":"image_picker","id":"image","label":"Image" },
      { "type":"text","id":"kicker","label":"Kicker" },
      { "type":"text","id":"heading","label":"Heading","default":"New Picks" },
      { "type":"text","id":"subheading","label":"Subheading" },
      { "type":"range","id":"overlay","min":0,"max":60,"step":5,"label":"Overlay darkness (%)","default":10 },
      { "type":"text","id":"link_label","label":"Button label","default":"Shop now" },
      { "type":"url","id":"link_url","label":"Button link" }
    ]}
  ],
  "max_blocks": 6,
  "presets":[{"name":"Hero slideshow"}]
}
{% endschema %}
